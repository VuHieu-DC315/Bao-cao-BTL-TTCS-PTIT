<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Giỏ hàng</title>
  <link rel="icon" type="image/jpeg" href="/image/Shop_logo.jpg" />
  <link rel="stylesheet" href="/css/cart.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>

  <script>
    function formatMoney(value) {
      return Number(value || 0).toLocaleString("vi-VN") + "đ";
    }

    function recalculateCartPreview() {
      let total = 0;

      $(".cart-row").each(function () {
        const price = Number($(this).data("price") || 0);
        const quantity = Number($(this).find(".qty-input").val() || 0);
        const lineTotal = price * quantity;

        $(this).find(".line-total-cell").text(formatMoney(lineTotal));
        total += lineTotal;
      });

      $("#cartTotalValue").text(formatMoney(total));
    }

    $(document).ready(function () {
      recalculateCartPreview();

      $(document).on("input change", ".qty-input", function () {
        const min = Number($(this).attr("min") || 1);
        const max = Number($(this).attr("max") || 1);
        let value = Number($(this).val() || min);

        if (!Number.isInteger(value) || value < min) {
          value = min;
        }

        if (value > max) {
          value = max;
        }

        $(this).val(value);
        recalculateCartPreview();
      });

      $("#btnBuyCart").click(function () {
        const currentTotalText = $("#cartTotalValue").text() || formatMoney(<%= total %>);
        $("#buyTotal").val(currentTotalText);
        $("#buyEmail").val("<%= user?.email || '' %>");
        $("#buyPhone").val("");
        $("#buyVoucherCode").val("");
        $("#buyModal").css("display", "block");
        $("body").css("overflow", "hidden");
      });

      $("#closeBuyModal").click(function () {
        $("#buyModal").hide();
        $("body").css("overflow", "auto");
      });

      $("#confirmBuy").click(function () {
        const email = $("#buyEmail").val().trim();
        const phone = $("#buyPhone").val().trim();
        const voucherCode = ($("#buyVoucherCode").val() || "").trim();

        if (!email || !phone) {
          alert("Vui lòng nhập email và số điện thoại");
          return;
        }

        $("#confirmBuy").prop("disabled", true).text("Đang xử lý...");

        $.ajax({
          url: "/cart/checkout",
          method: "POST",
          contentType: "application/json",
          data: JSON.stringify({
            email: email,
            phone: phone,
            voucherCode: voucherCode
          }),
          success: function (result) {
            alert(result?.message || "Thanh toán thành công!");
            $("#buyModal").hide();
            $("body").css("overflow", "auto");
            $("#buyVoucherCode").val("");
            window.location.href = "/cart";
          },
          error: function (error) {
            console.log(error);
            alert(error?.responseJSON?.message || "Thanh toán thất bại!");
          },
          complete: function () {
            $("#confirmBuy").prop("disabled", false).text("Xác nhận");
          }
        });
      });

      $(window).click(function (event) {
        if ($(event.target).is("#buyModal")) {
          $("#buyModal").hide();
          $("body").css("overflow", "auto");
        }
      });
    });
  </script>
</head>
<body>
  <header class="topbar">
      <div class="topbar-container">
          <a href="/" class="brand-logo" aria-label="Trang chủ">
              <img src="/image/Shop_logo.jpg" alt="Shop Logo" class="brand-logo-img" />
              <div class="brand-logo-text single">
                  <span class="brand-main">PShop</span>
                  <span class="brand-sub">Thế giới mua sắm đồ điện tử</span>
              </div>
          </a>
      </div>
  </header>

  <main class="page">
    <div class="page-header">
      <h2>Giỏ hàng tạm thời của bạn</h2>
      <div style="display:flex; gap:12px; align-items:center; flex-wrap:wrap;">
        <a href="/shop" class="back-link">← Quay lại mua hàng</a>
        <a href="/my-orders" class="back-link">Đơn hàng của tôi</a>
      </div>
    </div>

    <div class="cart-container">
      <% if (cartItems.length === 0) { %>
        <div class="empty-cart">Giỏ hàng trống</div>
      <% } else { %>
        <form action="/cart/items/update-all" method="POST" id="cartUpdateForm">
          <table class="cart-table">
            <thead>
              <tr>
                <th>Tên sản phẩm</th>
                <th>Giá</th>
                <th>Số lượng</th>
                <th>Thành tiền</th>
                <th>Hành động</th>
              </tr>
            </thead>
            <tbody>
              <% cartItems.forEach(item => { %>
                <tr class="cart-row" data-price="<%= Number(item.tutorial.price || 0) %>">
                  <td class="product-title-cell"><%= item.tutorial.title %></td>
                  <td><%= Number(item.tutorial.price || 0).toLocaleString('vi-VN') %>đ</td>
                  <td>
                    <input type="hidden" name="tutorialIds" value="<%= item.tutorialId %>">
                    <input
                      type="number"
                      name="quantities"
                      class="qty-input"
                      value="<%= item.quantity %>"
                      min="1"
                      max="<%= item.tutorial.quantity %>">
                    <div class="qty-note">Tối đa: <%= item.tutorial.quantity %></div>
                  </td>
                  <td class="line-total-cell"><%= Number(item.lineTotal || 0).toLocaleString('vi-VN') %>đ</td>
                  <td>
                    <button
                      type="submit"
                      class="btn-delete"
                      name="itemId"
                      value="<%= item.tutorialId %>"
                      formaction="/cart/items/delete"
                      formmethod="POST">
                      Xóa
                    </button>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>

          <div class="cart-footer">
            <div class="cart-total">Tổng tiền: <span id="cartTotalValue"><%= Number(total || 0).toLocaleString('vi-VN') %>đ</span></div>
            <div class="cart-actions">
              <button type="submit" class="btn-update-cart">Cập nhật giỏ hàng</button>
              <button type="button" id="btnBuyCart" class="btn-buy">Thanh toán</button>
            </div>
          </div>
        </form>
      <% } %>
    </div>
  </main>

  <div id="buyModal">
    <div class="modal-content">
      <h3>Thanh toán giỏ hàng</h3>

      <div class="form-group">
        <label>Tổng tiền:</label>
        <input type="text" id="buyTotal" readonly>
      </div>

      <div class="form-group">
        <label>Email:</label>
        <input type="email" id="buyEmail" placeholder="Nhập email của bạn">
      </div>

      <div class="form-group">
        <label>Số điện thoại:</label>
        <input type="text" id="buyPhone" placeholder="Nhập số điện thoại">
      </div>

      <div class="form-group">
        <label>Mã voucher:</label>

        <% if (user) { %>
          <select id="buyVoucherCode">
            <option value="">-- Không dùng voucher --</option>

            <% if (availableVouchers && availableVouchers.length > 0) { %>
              <% availableVouchers.forEach(function(voucher) { %>
                <option value="<%= voucher.code %>">
                  <%= voucher.code %> - <%= voucher.name %>
                  (
                  <%= voucher.discountType === 'percent'
                    ? voucher.discountValue + '%'
                    : Number(voucher.discountValue || 0).toLocaleString('vi-VN') + 'đ' %>
                  )
                </option>
              <% }) %>
            <% } %>
          </select>

          <% if (!availableVouchers || availableVouchers.length === 0) { %>
            <small class="voucher-note">Hiện chưa có voucher phù hợp cho giỏ hàng này</small>
          <% } %>
        <% } else { %>
          <select id="buyVoucherCode" disabled>
            <option value="">Đăng nhập để chọn voucher</option>
          </select>
          <small class="voucher-note">Chỉ user đã đăng nhập mới dùng được voucher</small>
        <% } %>
      </div>

      <div class="modal-actions">
        <button id="closeBuyModal" type="button">Hủy</button>
        <button id="confirmBuy" type="button">Xác nhận</button>
      </div>
    </div>
  </div>
</body>
</html>