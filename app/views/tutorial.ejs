<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Homepage</title>
</head>
<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>


<style>
    table {
        border-collapse: collapse;
        width: 100%;
    }

    th,
    td {
        padding: 8px;
        text-align: left;
        border-bottom: 1px solid #ddd;
    }

    tr:hover {
        background-color: #ccc;
    }

    body {
        padding: 10px;
    }
</style>

<script>
    $(document).ready(function () {
        $(".btnDelete").click(function () {
            const id = $(this).attr('data-id');
            if (confirm(`Are you sure to delete this tutorial, id = ${id}`)) {
                $.ajax({
                    url: `${window.location.origin}/api/tutorials/${id}`,
                    method: "DELETE",
                    success: (result) => {
                        console.log(result);
                        $(this).closest("tr").remove();
                    },
                    error: function (error) {
                        console.log(">>> ajax error: ", error)
                    }
                });
            } else {
                // Do nothing!
            }
        });
    });
</script>

<script>
    $(document).ready(function () {
        $(".btnUpdate").click(function () {
            const id = $(this).attr("data-id");
            const row = $(this).closest("tr");

            const title = row.find(".tdTitle").text().trim();
            const description = row.find(".tdDescription").text().trim();
            const published = row.find(".tdPublished").text().trim() === "true";

            $("#updateId").val(id);
            $("#updateTitle").val(title);
            $("#updateDescription").val(description);
            $("#updatePublished").prop("checked", published);

            $("#updateForm").show();
        });

        $("#saveUpdate").click(function () {
            const id = $("#updateId").val();

            const newData = {
                title: $("#updateTitle").val(),
                description: $("#updateDescription").val(),
                published: $("#updatePublished").is(":checked")
            };

            $.ajax({
                url: `${window.location.origin}/api/tutorials/${id}`,
                method: "PUT",
                contentType: "application/json",
                data: JSON.stringify(newData),
                success: function (result) {
                    console.log("Update success:", result);
                    alert("Update thành công");
                    location.reload();
                },
                error: function (error) {
                    console.log(">>> ajax error:", error);
                    alert("Update lỗi");
                }
            });
        });

        $("#cancelUpdate").click(function () {
            $("#updateForm").hide();
        });
    });
</script>

<body>
    <div>
        <a href="/tutorials/create">Create new Tutorial</a>
    </div>
    <div>
        <h3>List tutorials</h3>
        <table>
            <tr>
                <th>id</th>
                <th>Title</th>
                <th>Description</th>
                <th>Published</th>
                <th>Action</th>
            </tr>
            <% tutorials.forEach(function(item) { %>
                <tr>
                    <td> <img src="/image/<%= item.id %>.jpg" alt="tutorial image" width="80"> </td>
                    <td>
                        <%= item.id %>
                    </td>
                    <td class="tdTitle">
    <%= item.title %>
</td>
<td class="tdDescription">
    <%= item.description %>
</td>
<td class="tdPublished">
    <%= item.published %>
</td>
                    <td>
                        <button class="btnUpdate" data-id="<%=item.id%>">Update</button>
                        <button class="btnDelete" data-id="<%=item.id%>">Delete</button>
                    </td>
                </tr>
                <% }); %>


        </table>
        <div id="updateForm" style="display:none; margin-top:20px; border:1px solid #ccc; padding:15px;">
    <h3>Update tutorial</h3>

    <input type="hidden" id="updateId">

    <div style="margin-bottom:10px;">
        <label>Title:</label><br>
        <input type="text" id="updateTitle" style="width:300px;">
    </div>

    <div style="margin-bottom:10px;">
        <label>Description:</label><br>
        <input type="text" id="updateDescription" style="width:300px;">
    </div>

    <div style="margin-bottom:10px;">
        <label>
            <input type="checkbox" id="updatePublished">
            Published
        </label>
    </div>

    <button id="saveUpdate">Save</button>
    <button id="cancelUpdate">Cancel</button>
</div>
    </div>
</body>

</html>