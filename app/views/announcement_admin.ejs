<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <title>Quản lý thông báo</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      padding: 30px;
    }

    .box {
      width: 700px;
      margin: 0 auto;
      border: 1px solid #ccc;
      padding: 20px;
      border-radius: 8px;
    }

    input,
    textarea,
    button {
      width: 100%;
      padding: 10px;
      margin-bottom: 12px;
      box-sizing: border-box;
    }

    .announcement-item {
      border: 1px solid #ddd;
      padding: 12px;
      margin-top: 12px;
      border-radius: 6px;
    }
  </style>
</head>

<body>
  <div class="box">
    <h2>Quản lý thông báo</h2>

    <form method="POST" action="/announcements/admin/announcements">
      <label>Tiêu đề</label>
      <input type="text" name="title" required>

      <label>Nội dung</label>
      <textarea name="content" rows="4" required></textarea>

      <label>Ngày bắt đầu</label>
      <input type="datetime-local" name="startDate">

      <label>Ngày kết thúc</label>
      <input type="datetime-local" name="endDate">

      <label style="display:block; margin-bottom:12px;">
        <input type="checkbox" name="isPermanent" style="width:auto;">
        Thông báo vô thời hạn
      </label>

      <button type="submit">Đăng thông báo</button>
    </form>

    <hr>

    <h3>Danh sách thông báo</h3>

    <% if (announcements && announcements.length> 0) { %>
      <% announcements.forEach(function(item) { %>
        <div class="announcement-item">
          <h4>
            <%= item.title %>
          </h4>
          <p>
            <%= item.content %>
          </p>
          <p>Bắt đầu: <%= item.startDate ? item.startDate : "Không có" %>
          </p>
          <p>Kết thúc: <%= item.endDate ? item.endDate : "Không có" %>
          </p>
          <p>Vô thời hạn: <%= item.isPermanent ? "Có" : "Không" %>
          </p>
        </div>
        <% }) %>
          <% } else { %>
            <p>Chưa có thông báo nào.</p>
            <% } %>

              <br>
              <a href="/admin">Quay lại trang admin</a>
  </div>
</body>

</html>