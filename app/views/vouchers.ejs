<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Quản lý voucher</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/vouchers.css">
</head>
<body>
<%
  const voucherList = Array.isArray(vouchers) ? vouchers : [];

  function discountTypeLabel(type) {
    if (type === 'percent') return 'Phần trăm';
    if (type === 'fixed') return 'Tiền cố định';
    return type || '';
  }

  function formatDiscountValue(v) {
    if (v.discountType === 'percent') return `${Number(v.discountValue || 0)}%`;
    return `${Number(v.discountValue || 0).toLocaleString('vi-VN')}đ`;
  }

  function appliesToLabel(v) {
    if (v.appliesTo === 'all') return 'Toàn bộ sản phẩm';
    if (v.appliesTo === 'product' || v.appliesTo === 'tutorial') {
      if (v.tutorial && v.tutorial.title) return `Sản phẩm: ${v.tutorial.title}`;
      if (v.tutorial && v.tutorial.name) return `Sản phẩm: ${v.tutorial.name}`;
      if (v.tutorialId) return `Sản phẩm ID: ${v.tutorialId}`;
      return 'Sản phẩm cụ thể';
    }
    return v.appliesTo || '';
  }
%>

<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Quản lý voucher</h2>

    <div class="d-flex gap-2">
      <a href="/admin" class="btn btn-outline-secondary">← Về trang admin</a>
      <a href="/admin/vouchers/new" class="btn btn-primary">+ Thêm voucher</a>
    </div>
  </div>

  <% if (typeof successMessage !== 'undefined' && successMessage) { %>
    <div class="alert alert-success"><%= successMessage %></div>
  <% } %>

  <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
    <div class="alert alert-danger"><%= errorMessage %></div>
  <% } %>

  <div class="card shadow-sm">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle mb-0">
          <thead class="table-dark">
            <tr>
              <th>Code</th>
              <th>Tên</th>
              <th>Loại giảm</th>
              <th>Giá trị</th>
              <th>Đối tượng áp dụng</th>
              <th>Số lượng</th>
              <th>Used Count</th>
              <th>Active</th>
              <th style="width: 160px;">Thao tác</th>
            </tr>
          </thead>
          <tbody>
            <% if (!voucherList.length) { %>
              <tr>
                <td colspan="9" class="text-center py-4">Chưa có voucher nào</td>
              </tr>
            <% } %>

            <% voucherList.forEach(function(voucher) { %>
              <tr>
                <td><strong><%= voucher.code %></strong></td>
                <td><%= voucher.name %></td>
                <td><%= discountTypeLabel(voucher.discountType) %></td>
                <td><%= formatDiscountValue(voucher) %></td>
                <td><%= appliesToLabel(voucher) %></td>
                <td><%= voucher.quantity || 0 %></td>
                <td><%= voucher.usedCount || 0 %></td>
                <td>
                  <% if (voucher.isActive || voucher.active) { %>
                    <span class="badge bg-success">Đang bật</span>
                  <% } else { %>
                    <span class="badge bg-secondary">Đang tắt</span>
                  <% } %>
                </td>
                <td>
                  <div class="d-flex gap-2">
                    <a href="/admin/vouchers/<%= voucher.id %>/edit" class="btn btn-warning btn-sm">
                      Sửa
                    </a>

                    <form action="/admin/vouchers/<%= voucher.id %>/delete" method="POST" onsubmit="return confirm('Bạn có chắc muốn xóa voucher này?');">
                      <button type="submit" class="btn btn-danger btn-sm">Xóa</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
</body>
</html>