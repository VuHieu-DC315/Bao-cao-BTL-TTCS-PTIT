<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Quên mật khẩu</title>
  <link rel="stylesheet" href="/css/login.css">
</head>
<body>
  <main class="page">
    <section class="auth-shell">
      <div class="login-side" style="margin: 0 auto;">
        <div class="login-box">
          <h2 class="login-title">Quên mật khẩu</h2>

          <% if (error) { %>
            <p style="color: red; margin-bottom: 12px;"><%= error %></p>
          <% } %>

          <% if (success) { %>
            <p style="color: green; margin-bottom: 12px;"><%= success %></p>
          <% } %>

          <form method="POST" action="/forgot-password">
            <div class="form-group">
              <label for="tk">Tài khoản</label>
              <input type="text" id="tk" name="tk" placeholder="Nhập tài khoản của bạn" required>
            </div>

            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" placeholder="Nhập email đã đăng ký" required>
            </div>

            <button type="submit" class="login-btn">Yêu cầu mật khẩu mới</button>
          </form>

          <div class="bottom-text">
            <div class="home-back">
              <a href="/login">Quay lại đăng nhập</a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</body>
</html>