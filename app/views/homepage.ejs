<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sales Page</title>
</head>

<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>

<style>
    table {
        border-collapse: collapse;
        width: 100%;
    }

    th,
    td {
        padding: 8px;
        text-align: left;
        border-bottom: 1px solid #ddd;
    }

    tr:hover {
        background-color: #ccc;
    }

    body {
        padding: 10px;
    }

    .announcement-section {
        margin-bottom: 25px;
        padding: 15px;
        border: 1px solid #ddd;
        border-radius: 8px;
        background: #fafafa;
    }

    .announcement-item {
        padding: 10px 0;
        border-bottom: 1px solid #ddd;
    }

    .announcement-item:last-child {
        border-bottom: none;
    }

    .hidden-announcement {
        display: none;
    }

    #btnShowMore {
        margin-top: 10px;
        padding: 8px 12px;
        cursor: pointer;
    }
</style>

<script>
    $(document).ready(function () {
        $(".btnBuy").click(function () {
            const id = $(this).attr("data-id");
            window.location.href = `${window.location.origin}/homepage/${id}`;
        });

        $("#btnShowMore").click(function () {
            $(".hidden-announcement").slideDown();
            $(this).hide();
        });
    });
</script>

<body>
    <div style="margin-bottom: 15px;">
        <a href="/cart">Xem giỏ hàng</a>
        <% if (user) { %>
            <a href="/logout">Đăng xuất</a>
            <% } else { %>
                <a href="/login">Đăng nhập</a>
                <% } %>
    </div>

    <% if (announcements && announcements.length> 0) { %>
        <% announcements.forEach(function(item) { %>
            <div style="border:1px solid #ddd; border-radius:10px; padding:16px; margin-bottom:20px;">
                <h2>Thông báo</h2>
                <p><strong>
                        <%= item.title %>
                    </strong></p>
                <p>
                    <%= item.content %>
                </p>

                <% if (item.isPermanent) { %>
                    <p>Thông báo vĩnh viễn</p>
                    <% } else if (item.startDateVN || item.endDateVN) { %>
                        <p>
                            Từ:
                            <%= item.startDateVN || "Không giới hạn" %>
                                - Đến:
                                <%= item.endDateVN || "Không giới hạn" %>
                        </p>
                        <% } %>
            </div>
            <% }) %>

                <% if (hasMoreAnnouncements) { %>
                    <div style="margin-bottom:20px;">
                        <a href="/announcements">Xem thêm</a>
                    </div>
                    <% } %>
                        <% } %>
                            <div>
                                <h3>List tutorials</h3>
                                <table>
                                    <tr>
                                        <th>Ảnh</th>
                                        <th>ID</th>
                                        <th>Title</th>
                                        <th>Description</th>
                                        <th>Price</th>
                                        <th>Published</th>
                                        <th>Action</th>
                                    </tr>

                                    <% tutorials.forEach(function(item) { %>
                                        <tr>
                                            <td>
                                                <img src="/image/<%= item.id %>.jpg" alt="tutorial image" width="80">
                                            </td>
                                            <td>
                                                <%= item.id %>
                                            </td>
                                            <td>
                                                <%= item.title %>
                                            </td>
                                            <td>
                                                <%= item.description %>
                                            </td>
                                            <td>
                                                <%= item.price %>
                                            </td>
                                            <td>
                                                <%= item.published %>
                                            </td>
                                            <td>
                                                <button class="btnBuy" data-id="<%= item.id %>" <%=item.published ? ""
                                                    : "disabled" %>>
                                                    Buy
                                                </button>
                                            </td>
                                        </tr>
                                        <% }) %>
                                </table>
                            </div>
</body>

</html>